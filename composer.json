{
    "name": "1platform/content-ai",
    "description": "1Platform Content AI WordPress Plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "10up/wp_mock": "^1.0",
        "mockery/mockery": "^1.6"
    },
    "autoload-dev": {
        "psr-4": {
            "ContAI\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist",
        "test:coverage": "phpunit --configuration phpunit.xml.dist --coverage-text",
        "test:filter": "phpunit --configuration phpunit.xml.dist --filter"
    },
    "config": {
        "allow-plugins": {},
        "sort-packages": true
    }
}
